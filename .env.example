# Google Drive Config
# Set ONE of these (see README for details):
#   - GOOGLE_APPLICATION_CREDENTIALS for Shared Drives (Google Workspace)
#   - OAUTH_CREDENTIALS_FILE for personal Google accounts
GOOGLE_APPLICATION_CREDENTIALS=service-account.json
# OAUTH_CREDENTIALS_FILE=credentials.json
# OAUTH_TOKEN_FILE=/absolute/path/to/token.json
# If omitted, defaults to the platform config dir token:
#   Linux/macOS: ~/.config/apkdist/token.json
#   Windows: %APPDATA%\\apkdist\\token.json

DRIVE_FOLDER_ID=1A2B3C4D5E6F7G8H9I0J

# Telegram Config
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=-100123456789

# Android Project Config
# Use absolute path to the android project root (where gradlew lives)
ANDROID_PROJECT_PATH=/path/to/android-project
APP_MODULE_NAME=app
