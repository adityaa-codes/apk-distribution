# Android project
ANDROID_PROJECT_PATH=/absolute/path/to/android-project
APP_MODULE_NAME=app

# Google Drive target
DRIVE_FOLDER_ID=1A2B3C4D5E6F7G8H9I0J

# Drive auth: set ONE of the following
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# OAUTH_CREDENTIALS_FILE=/absolute/path/to/credentials.json
# OAUTH_TOKEN_FILE=/absolute/path/to/token.json

# Telegram target
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=-100123456789
# TELEGRAM_THREAD_ID=1234

# Telegram delivery
TELEGRAM_SEND_DOCUMENT=true
# TELEGRAM_CLOUD_DOCUMENT_LIMIT_MB=50

# Optional local Telegram Bot API server
# TELEGRAM_API_BASE_URL=http://localhost:8081
# TELEGRAM_API_ID=12345678
# TELEGRAM_API_HASH=0123456789abcdef0123456789abcdef
